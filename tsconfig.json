{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ES2018",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "DOM",
      "ES2018"
    ]
  },
  "include": [
    "**/*.ts"
  ]
}
